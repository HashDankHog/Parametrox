{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parametrox",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "beforeDevCommand": "tsc -p parametrox",
    "beforeBuildCommand": "tsc -p parametrox",
    "frontendDist": ["app/ui"]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "test_app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "app/icons/32x32.png",
      "app/icons/128x128.png",
      "app/icons/128x128@2x.png",
      "app/icons/icon.icns",
      "app/icons/icon.ico"
    ]
  }
}