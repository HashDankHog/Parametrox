{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parametrox",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": ["scene/src/site"]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "test_app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "scene/icons/32x32.png",
      "scene/icons/128x128.png",
      "scene/icons/128x128@2x.png",
      "scene/icons/icon.icns",
      "scene/icons/icon.ico"
    ]
  }
}