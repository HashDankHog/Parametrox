{
  "compilerOptions": {
    "module": "commonjs",
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true
  },
  "include": ["app/ui/**/*"],
  "exclude": ["app/ui/**/*.spec.ts"]
}